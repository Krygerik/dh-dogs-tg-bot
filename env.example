# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_bot_token_here

# Public IP address shown to players
PUBLIC_IP=185.17.66.195

# Path to Dread Hunger server binary
BINARY_PATH=C:\Users\Server\WindowsServer\DreadHunger\Binaries\Win64\DreadHungerServer-Win64-Shipping.exe

# Ports (single, comma separated, or ranges)
PORTS=7777-7782

# Optional Frida injector script (bat/cmd/exe)
FRIDA_PATH=.\frida\python_loader.bat

# External API for client app
API_TOKEN=change_me

# Base port for telemetry HTTP bridge when a session is started with enableTelemetry (API /run)
# Actual port = base + game server port
TELEMETRY_BASE_PORT=8790

